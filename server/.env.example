# ==========================================================================
# AI学習コーチ塾 Backend Environment Variables
# ==========================================================================
# このファイルを .env にコピーして、実際の値を設定してください。
# コピー後: cp .env.example .env

# ========== 基本設定 ==========
BASE_URL=http://localhost:8000
# 本番環境では: BASE_URL=https://ai-juku.example

# ========== Stripe 決済 ==========
# https://dashboard.stripe.com/apikeys から取得
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product/Price IDs
# Stripeダッシュボード > Products で3プランを作成後、各priceのIDを設定
STRIPE_PRICE_AI=price_XXXXX_ai_completion
STRIPE_PRICE_HYBRID=price_XXXXX_hybrid
STRIPE_PRICE_INTENSIVE=price_XXXXX_intensive

# ========== LINE Messaging API ==========
# https://developers.line.biz/console/ から取得
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# ========== Anthropic (Claude) ==========
# 生徒のAPIキーとは別の、サーバーサイド用のキー
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ========== Cron認証 ==========
# 外部cronサービス (Render Cron, GitHub Actions, cron-job.org など) からの認証用
# ランダムな長い文字列を設定
CRON_SECRET=change_me_to_random_long_string
