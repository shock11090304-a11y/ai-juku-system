# ==========================================================================
# AI学習コーチ塾 - 環境変数テンプレート
# 本番環境で .env ファイルにコピーして使用してください（.env は git 無視）
# ==========================================================================

# --- Anthropic API ---
# https://console.anthropic.com/ でAPIキー取得
ANTHROPIC_API_KEY=sk-ant-api-your-key-here

# --- Stripe 決済 ---
# https://dashboard.stripe.com/apikeys でキー取得
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here

# Stripe商品のPrice ID（ダッシュボードで商品作成後）
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx
STRIPE_PRICE_FAMILY=price_xxx
STRIPE_PRICE_STUDENT_ADDON=price_xxx
STRIPE_PRICE_TRIAL=price_xxx
STRIPE_PRICE_ENROLLMENT=price_xxx

# 後方互換（旧プラン名）
STRIPE_PRICE_AI=price_xxx
STRIPE_PRICE_HYBRID=price_xxx
STRIPE_PRICE_INTENSIVE=price_xxx

# --- 認証（マジックリンク方式）---
# 32文字以上のランダム値を推奨。`python3 -c "import secrets; print(secrets.token_urlsafe(48))"` で生成可能
# 本番ではこの値が漏洩すると全ユーザーのセッション偽造が可能になるため厳重管理
MAGIC_LINK_SECRET=generate-a-random-48-char-string
# セッションの有効期限（秒）。既定 30日。短くしたい場合は 604800 (7日) 等
SESSION_TTL_SECONDS=2592000

# --- Resend (メール送信サービス) ---
# https://resend.com/api-keys で取得。月3000通まで無料
# 未設定時は開発モードとしてログイン URL をコンソール出力にフォールバック
RESEND_API_KEY=re_your_key_here
# 送信元。独自ドメインを Resend で verify すれば info@trillion-ai-juku.com などに変更可
FROM_EMAIL="AI学習コーチ塾 <onboarding@resend.dev>"

# --- LINE Messaging API（廃止予定・未使用）---
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=

# --- サイト基本設定 ---
BASE_URL=https://your-domain.com
